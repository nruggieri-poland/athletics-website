# Example nginx server block. Cloudflare (orange-clouded DNS) sits in front
# of this box, so the firewall should restrict inbound 80/443 to Cloudflare's
# published IP ranges (https://www.cloudflare.com/ips/) plus SSH from your IP.
#
# apps/web is a fully static Astro build — nginx serves the built files
# directly from disk, no Node process involved for the public site.
# apps/cms (Payload/Next.js admin UI + REST/GraphQL API) is the only
# proxied upstream, on its own subdomain so the admin/API surface is never
# exposed under the main domain.
#
# root points at `current`, a symlink flipped atomically by
# apps/web/deploy-build.sh after each successful build — NOT at `dist`
# directly. Astro clears its output directory at the start of every build,
# so pointing nginx straight at it means visitors see 404s for the few
# seconds a rebuild takes, every single time content is published.

server {
    listen 80;
    server_name polandbulldogs.org www.polandbulldogs.org;

    root /var/www/athletics-website/apps/web/current;
    index index.html;

    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location / {
        try_files $uri $uri/index.html =404;

        # Safety-net cache header; Cloudflare edge-caches on top of this.
        # The rebuild hook (apps/cms/src/hooks/rebuildWeb.ts) purges
        # Cloudflare's cache right after every rebuild, so this TTL only
        # matters if that purge call ever fails.
        add_header Cache-Control "public, max-age=3600, stale-while-revalidate=86400";
    }

    location /_astro/ {
        # Hashed, immutable build assets — safe to cache hard.
        add_header Cache-Control "public, max-age=31536000, immutable";
    }
}

server {
    listen 80;
    server_name cms.polandbulldogs.org;

    # X-Content-Type-Options matters here more than on the static site:
    # Media has public read access, so an uploaded file's raw URL is
    # directly browsable — without nosniff, a browser could reinterpret a
    # file as a different content type than the one Payload declared.
    # X-Frame-Options/frame-ancestors stop the admin login/dashboard from
    # being framed by another site for a clickjacking overlay.
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Content-Security-Policy "frame-ancestors 'self'" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Admin UI and API responses are dynamic — never cache.
        add_header Cache-Control "no-store";
    }

    client_max_body_size 25m; # media uploads
}

# TLS: terminate at Cloudflare (Full or Full-Strict SSL mode) and/or run
# certbot for a origin certificate — add the standard `listen 443 ssl;`
# blocks once a certificate is issued. Omitted here since it's
# environment-specific.
