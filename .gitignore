node_modules/
dist/
dist*/
# Catches "dist 2", "dist copy", etc. — macOS appends a suffix like this to
# a folder name when it thinks it's resolving a duplicate, which doesn't
# match a plain `dist/` pattern. A build output folder got committed this
# way once already.
apps/web/dist-blue/
apps/web/dist-green/
apps/web/current
.env
.env.*
!.env.example
*.log
.DS_Store
apps/web/.astro/
apps/cms/build/
apps/cms/.next/
.claude/

# Payload's own uploaded-file storage — runtime data that belongs on the
# server's disk, not in version control (also true for anything editors
# upload through the CMS admin, not just the items below).
apps/cms/media/

# Raw opponent logo source images — large (hundreds of files), not meant to
# be tracked in git. These get bulk-uploaded directly into Payload's Media
# library through the admin UI, not deployed via git pull. opponents.json
# (the small name/mascot/alias mapping seed-opponents.ts reads) is NOT
# covered by this pattern and stays tracked.
scripts/opponent-logos/*.png

# deploy.sh's own record of the last commit it successfully finished
# deploying, and its consecutive-failure counter for the current commit —
# server-local state, never meant to be shared or committed. Committing
# either would recreate the exact "local file drift blocks git pull"
# problem deploy.sh works around for package-lock.json and next-env.d.ts:
# every server would fight over whose deploy state is real.
.deploy-state
.deploy-failstate

# deploy.sh's rollback copy of the last known-good CMS build — renamed
# here right before a risky build, restored if the new one fails its
# health check. Same reason as apps/cms/.next/ above: build output, not
# source.
apps/cms/.next.last-good/
