---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CtaBand from "../../components/shared/CtaBand.astro";
import { getLinksByPlacement, type Link } from "../../lib/payload";

const links = await getLinksByPlacement("watchLive");
---

<BaseLayout title="Watch Live" description="Ways to watch Poland Seminary Bulldogs games live.">
  <div class="mx-auto max-w-content px-6">
    <div class="border-b border-ink-100 py-12">
      <h1 class="max-w-[20ch] text-h1 font-bold text-ink-900">Watch Live</h1>
      <p class="mt-3 max-w-[62ch] text-lg text-ink-600">Ways to watch Bulldogs games live.</p>
    </div>

    <div class="py-14">
      {links.length > 0 ? (
        links.map((link: Link) => (
          <CtaBand
            title={link.title}
            body={link.description}
            ctaLabel={link.ctaLabel || "Watch now"}
            ctaUrl={link.url || "#"}
            logo={link.logo}
          />
        ))
      ) : (
        <p class="text-ink-400">Nothing published here yet — check back soon.</p>
      )}
    </div>
  </div>
</BaseLayout>
