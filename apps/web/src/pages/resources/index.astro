---
import BaseLayout from "../../layouts/BaseLayout.astro";

// This page mostly exists as a fallback for direct navigation and no-JS —
// on desktop, "Resources" is normally reached by hovering the header menu
// and going straight to one of these three, without landing here first.
const links = [
  {
    href: "/resources/parents",
    label: "Parents",
    description: "Registration, physicals, policies & contacts",
    iconPath:
      "M6.5 9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Zm7 0a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM2 16c0-2.5 2-4.5 4.5-4.5S11 13.5 11 16m1-4.5c2.2 0 4 1.8 4 4.5",
  },
  {
    href: "/resources/coaches",
    label: "Coaches",
    description: "Handbook, required forms & compliance",
    iconPath: "M4 16v-1.5A3.5 3.5 0 0 1 7.5 11h5a3.5 3.5 0 0 1 3.5 3.5V16M10 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z",
  },
  {
    href: "/resources/fans",
    label: "Fans & Community",
    description: "Tickets, gameday info & ways to support",
    iconPath: "M10 16.5s-6-3.6-6-8.1a3.6 3.6 0 0 1 6-2.7 3.6 3.6 0 0 1 6 2.7c0 4.5-6 8.1-6 8.1Z",
  },
];
---

<BaseLayout title="Resources" description="Resources for parents, coaches, and fans of Poland Seminary Bulldogs Athletics">
  <section class="mx-auto max-w-content px-6 py-16">
    <h1 class="mb-2 text-h1 font-bold text-ink-900">Resources</h1>
    <p class="mb-10 text-ink-500">Choose who you are to see what's relevant to you.</p>

    <div class="grid gap-4 sm:grid-cols-3">
      {links.map((link) => (
        <a href={link.href} class="flex flex-col gap-3 rounded-xl border border-ink-100 p-6 hover:border-primary-200 hover:bg-ink-50">
          <span class="grid h-11 w-11 place-items-center rounded-lg bg-primary-50 text-primary-700">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d={link.iconPath} stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>
            <span class="block text-lg font-bold text-ink-900">{link.label}</span>
            <span class="mt-1 block text-sm text-ink-500">{link.description}</span>
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
