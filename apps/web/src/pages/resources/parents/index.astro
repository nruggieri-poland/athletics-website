---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/resources/PageHero.astro";
import GalleryView from "../../../components/galleries/GalleryView.astro";
import { getGalleryBySlug } from "../../../lib/payload";

const gallery = await getGalleryBySlug("parents");

---

<BaseLayout title="For Parents" description="Registration, physicals, policies, and contacts for Poland Seminary Bulldogs Athletics parents">
  <div class="mx-auto max-w-content px-6">
    <PageHero
      section="Parents"
      title="For Parents"
      lede=""
    />

    <div class="space-y-14 py-14">
      <section>
        <h2 class="mb-5 text-h3 font-bold text-ink-900">Resources</h2>
        {gallery ? (
          <GalleryView gallery={gallery} emptyLabel="No resources published yet — check back soon." />
        ) : (
          <p class="text-ink-400">No resources published yet — check back soon.</p>
        )}
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  /* Same Safari fix as the mobile nav accordion in Header.astro — list-none
     handles Firefox/Chrome, but Safari renders <summary> markers via a
     separate pseudo-element that list-style doesn't reach. */
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
</style>
