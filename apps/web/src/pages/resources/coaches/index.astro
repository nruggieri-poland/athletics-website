---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/resources/PageHero.astro";
import DocumentGroups from "../../../components/resources/DocumentGroups.astro";
import ContactGrid from "../../../components/resources/ContactGrid.astro";
import { getPublicDocumentsByAudience } from "../../../lib/payload";

const documents = await getPublicDocumentsByAudience("coaches");

---

<BaseLayout title="For Coaches" description="Handbook, forms, and compliance for Poland Seminary Bulldogs Athletics coaches">
  <div class="mx-auto max-w-content px-6">
    <PageHero
      section="Coaches"
      title="For Coaches"
      lede="Test"
    />

    <div class="grid gap-10 py-14 md:grid-cols-[1fr_280px]">
      <section>
        <h2 class="mb-5 text-h3 font-bold text-ink-900">Documents</h2>
        <DocumentGroups documents={documents} emptyLabel="No documents published yet — check back soon." />
      </section>
    </div>
  </div>
</BaseLayout>
