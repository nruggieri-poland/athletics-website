---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/resources/PageHero.astro";
import ArticlesCarousel from "../../../components/articles/ArticlesCarousel.astro";
import { getArticlesForTag } from "../../../lib/payload";

// The rest of this page (gameday guide, tickets, merch, etc.) was placeholder
// content that never got real data — pulled for now, full source saved at
// docs/fans-page-draft.md if it's worth reviving later.
const fanArticles = await getArticlesForTag("fans");
---

<BaseLayout title="For Fans & Community" description="News and updates for Poland Seminary Bulldogs Athletics fans">
  <div class="mx-auto max-w-content px-6">
    <PageHero
      section="Fans & Community"
      title="For Fans & Community"
      lede="What's happening around Bulldogs Athletics."
    />

    <div class="py-14">
      <h2 class="mb-5 text-h3 font-bold text-ink-900">News</h2>
      {fanArticles.length > 0 ? (
        <ArticlesCarousel articles={fanArticles} />
      ) : (
        <p class="text-ink-400">No fan news posted yet — check back soon.</p>
      )}
    </div>
  </div>
</BaseLayout>
