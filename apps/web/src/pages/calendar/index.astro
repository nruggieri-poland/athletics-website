---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EventLinkPromo from "../../components/shared/EventLinkPromo.astro";
import { getSchoolYearGames, getSports, levelSlug, mediaUrl } from "../../lib/payload";
import type { TeamLevel } from "../../lib/payload";

const LEVEL_GROUPS = ["Varsity", "Junior Varsity", "Freshman", "Junior High"] as const;
type LevelGroup = (typeof LEVEL_GROUPS)[number];

// 7th/8th Grade and Junior High are all the same "level" for filtering
// purposes — parents think in terms of "Junior High," not grade number.
function levelGroup(level: TeamLevel): LevelGroup {
  if (level === "8th Grade" || level === "7th Grade" || level === "Junior High") return "Junior High";
  return level;
}

// Short form for tight card layouts — "Junior Varsity" would eat most of a
// month-view pill's width on its own.
function levelAbbrev(level: TeamLevel): string {
  if (level === "Junior Varsity") return "JV";
  if (level === "7th Grade") return "7th";
  if (level === "8th Grade") return "8th";
  return level;
}

const [games, sports] = await Promise.all([getSchoolYearGames(), getSports()]);

// Flattened, client-friendly shape — resolving media URLs and team hrefs
// here (server-side) means the client script never needs the full Payload
// type graph, just plain strings/numbers/booleans.
const events = games.map((game) => ({
  id: String(game.id),
  date: game.date.slice(0, 10),
  time: game.isTimeTBD || !game.time ? null : game.time,
  homeOrAway: game.homeOrAway,
  opponentName: game.opponentName ?? "",
  opponentMascot: game.opponentMascot ?? null,
  opponentLogoUrl: game.opponentLogo ? mediaUrl(game.opponentLogo) : null,
  location: game.location ?? null,
  isConferenceGame: game.isConferenceGame,
  isCancelled: game.isCancelled,
  isPostponed: game.isPostponed,
  result: game.result || null,
  homeScore: typeof game.homeScore === "number" ? game.homeScore : null,
  awayScore: typeof game.awayScore === "number" ? game.awayScore : null,
  teamName: game.team.displayName,
  sportName: game.team.sport.name,
  levelAbbrev: levelAbbrev(game.team.level),
  teamHref: `/${game.team.sport.slug}/${levelSlug(game.team.level)}`,
  sportId: String(game.team.sport.id),
  levelGroup: levelGroup(game.team.level),
}));

const sportsForFilter = [...sports]
  .filter((sport) => events.some((e) => e.sportId === String(sport.id)))
  .sort((a, b) => a.name.localeCompare(b.name))
  .map((s) => ({ id: String(s.id), name: s.name }));

// Escape "</" so the JSON payload can never prematurely close the <script>
// tag it's embedded in, however unlikely (an opponent name from the CMS
// would have to literally contain "</script>").
const eventsJson = JSON.stringify(events).replace(/</g, "\\u003c");
const sportsJson = JSON.stringify(sportsForFilter).replace(/</g, "\\u003c");
---

<BaseLayout title="Calendar" description="Full athletics calendar for every Poland Seminary team">
  <section class="mx-auto max-w-content px-6 py-12">
    <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
      <h1 class="text-h1 font-bold text-ink-900">Calendar</h1>
      <a
        href="/calendar/print"
        class="rounded-md border border-ink-200 px-3 py-2 text-sm font-medium text-ink-600 hover:bg-ink-50"
      >
        Print / PDF full schedule
      </a>
    </div>

    <div class="mb-4 flex flex-wrap items-center gap-3">
      <div role="group" aria-label="Calendar view" class="flex flex-wrap rounded-md border border-ink-200 p-0.5">
        {["Agenda", "Month", "Week", "Day"].map((label) => (
          <button
            type="button"
            data-view-btn={label.toLowerCase()}
            aria-pressed={label === "Agenda" ? "true" : "false"}
            class:list={[
              "rounded px-3 py-1.5 text-sm font-medium text-ink-600 aria-pressed:bg-primary-600 aria-pressed:text-white",
              // Month is a fixed 7-column grid with no room to shrink —
              // on a phone it renders as unreadable ~48px-wide cells, so
              // it isn't offered as an option below that width at all.
              label === "Month" && "hidden sm:inline-block",
            ]}
          >
            {label}
          </button>
        ))}
      </div>

      <label class="flex items-center gap-2 text-sm text-ink-500">
        Sport
        <select
          id="calendar-sport-filter"
          class="rounded-md border border-ink-200 bg-surface px-2 py-1.5 text-sm text-ink-700"
        >
          <option value="all">All Sports</option>
          {sportsForFilter.map((sport) => (
            <option value={sport.id}>{sport.name}</option>
          ))}
        </select>
      </label>

      <label class="flex items-center gap-2 text-sm text-ink-500">
        Level
        <select
          id="calendar-level-filter"
          class="rounded-md border border-ink-200 bg-surface px-2 py-1.5 text-sm text-ink-700"
        >
          <option value="all">All Levels</option>
          {LEVEL_GROUPS.map((group) => (
            <option value={group}>{group}</option>
          ))}
        </select>
      </label>

      <div class="ml-auto flex items-center gap-2">
        <button
          type="button"
          id="calendar-today"
          class="rounded-md border border-ink-200 px-3 py-1.5 text-sm font-medium text-ink-600 hover:bg-ink-50"
        >
          Today
        </button>
        <button
          type="button"
          id="calendar-prev"
          aria-label="Previous"
          class="rounded-md border border-ink-200 p-3.5 text-ink-600 hover:bg-ink-50"
        >
          <svg class="h-4 w-4" viewBox="0 0 12 12" fill="none">
            <path d="M8 2L4 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <button
          type="button"
          id="calendar-next"
          aria-label="Next"
          class="rounded-md border border-ink-200 p-3.5 text-ink-600 hover:bg-ink-50"
        >
          <svg class="h-4 w-4" viewBox="0 0 12 12" fill="none">
            <path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </div>

    <p id="calendar-period-label" aria-live="polite" class="mb-4 text-sm font-semibold uppercase tracking-wide text-ink-500">
      Full Season
    </p>

    <div id="calendar-content"></div>

    <div class="mt-10">
      <EventLinkPromo />
    </div>
  </section>
</BaseLayout>

<script is:inline type="application/json" id="calendar-events-data" set:html={eventsJson} />
<script is:inline type="application/json" id="calendar-sports-data" set:html={sportsJson} />

<script>
  interface CalEvent {
    id: string;
    date: string;
    time: string | null;
    homeOrAway: "Home" | "Away" | "Neutral";
    opponentName: string;
    opponentMascot: string | null;
    opponentLogoUrl: string | null;
    location: string | null;
    isConferenceGame: boolean;
    isCancelled: boolean;
    isPostponed: boolean;
    result: "W" | "L" | "T" | "" | null;
    homeScore: number | null;
    awayScore: number | null;
    teamName: string;
    sportName: string;
    levelAbbrev: string;
    teamHref: string;
    sportId: string;
    levelGroup: "Varsity" | "Junior Varsity" | "Freshman" | "Junior High";
  }

  const allEvents: CalEvent[] = JSON.parse(
    document.getElementById("calendar-events-data")!.textContent || "[]",
  );

  // ── Date helpers — all local-time, no UTC conversion anywhere, so a game
  // dated "2026-08-07" always means Aug 7 in the visitor's own calendar,
  // never shifted a day by a UTC round-trip (a classic date-picker bug). ──
  function parseLocalDate(dateStr: string): Date {
    return new Date(`${dateStr}T00:00:00`);
  }
  function ymd(d: Date): string {
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
  }
  function addDays(d: Date, n: number): Date {
    const r = new Date(d);
    r.setDate(r.getDate() + n);
    return r;
  }
  function addMonths(d: Date, n: number): Date {
    const r = new Date(d);
    r.setMonth(r.getMonth() + n, 1);
    return r;
  }
  function startOfWeek(d: Date): Date {
    const r = new Date(d);
    r.setDate(r.getDate() - r.getDay());
    return r;
  }

  function groupByDate(events: CalEvent[]): Map<string, CalEvent[]> {
    const map = new Map<string, CalEvent[]>();
    for (const e of events) {
      if (!map.has(e.date)) map.set(e.date, []);
      map.get(e.date)!.push(e);
    }
    return map;
  }

  // ── DOM builders ─────────────────────────────────────────────────────────
  function el<K extends keyof HTMLElementTagNameMap>(
    tag: K,
    className?: string,
    text?: string,
  ): HTMLElementTagNameMap[K] {
    const node = document.createElement(tag);
    if (className) node.className = className;
    if (text !== undefined) node.textContent = text;
    return node;
  }

  function badge(text: string, className: string): HTMLElement {
    return el("span", `shrink-0 rounded-full px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide ${className}`, text);
  }

  function buildEventRow(ev: CalEvent): HTMLElement {
    // Tighter padding + fewer lines than the original 3-line layout, so a
    // phone screen fits noticeably more games before scrolling — the
    // Agenda view is the default on mobile (Month isn't offered there),
    // so it's the one view that most needs to earn its vertical space.
    const row = el(
      "div",
      "flex flex-wrap items-center gap-x-3 gap-y-0.5 rounded-lg border border-ink-100 bg-surface px-3 py-2 sm:px-4 sm:py-3" +
        (ev.isCancelled || ev.isPostponed ? " opacity-60" : ""),
    );

    row.appendChild(
      badge(
        ev.homeOrAway,
        ev.homeOrAway === "Home" ? "bg-primary-50 text-primary-700" : "bg-ink-100 text-ink-600",
      ),
    );

    const main = el("div", "min-w-0 flex-1");
    const teamLink = el("a", "text-xs font-semibold uppercase tracking-wide text-primary-600 hover:underline", ev.teamName);
    teamLink.href = ev.teamHref;
    main.appendChild(teamLink);

    const oppRow = el("div", "flex min-w-0 flex-wrap items-baseline gap-x-1.5");
    if (ev.opponentLogoUrl) {
      const img = el("img", "h-4 w-4 shrink-0 self-center object-contain");
      img.src = ev.opponentLogoUrl;
      img.alt = "";
      img.loading = "lazy";
      oppRow.appendChild(img);
    }
    const vsOrAt = ev.homeOrAway === "Home" ? "vs" : ev.homeOrAway === "Away" ? "@" : "";
    const oppText = `${vsOrAt} ${ev.opponentName}${ev.opponentMascot ? " " + ev.opponentMascot : ""}`.trim();
    oppRow.appendChild(el("p", "truncate text-sm font-medium text-ink-900", oppText));
    const metaBits = [ev.time ?? "TBD"];
    if (ev.location) metaBits.push(ev.location);
    oppRow.appendChild(el("p", "shrink-0 text-xs text-ink-400", `· ${metaBits.join(" · ")}`));
    main.appendChild(oppRow);

    row.appendChild(main);

    const right = el("div", "ml-auto flex shrink-0 items-center gap-2");
    if (ev.isCancelled) {
      right.appendChild(badge("Cancelled", "bg-ink-100 text-ink-600"));
    } else if (ev.isPostponed) {
      right.appendChild(badge("Postponed", "bg-ink-100 text-ink-600"));
    } else if (ev.result && ev.homeScore !== null && ev.awayScore !== null) {
      const cls = ev.result === "W" ? "text-green-700" : ev.result === "L" ? "text-red-700" : "text-ink-600";
      right.appendChild(el("span", `text-sm font-semibold ${cls}`, `${ev.result} ${ev.homeScore}-${ev.awayScore}`));
    }
    if (ev.isConferenceGame) right.appendChild(badge("Conf", "bg-primary-50 text-primary-700"));
    row.appendChild(right);

    return row;
  }

  // role="status" so screen readers announce "no games" automatically when a
  // filter change empties the view, instead of it silently appearing blank.
  function emptyMessage(text = "No games in this period."): HTMLElement {
    const p = el("p", "text-sm text-ink-400", text);
    p.setAttribute("role", "status");
    return p;
  }

  // ── Month-windowed loading ──────────────────────────────────────────────
  // Agenda is a flat list across the whole season (hundreds of games) —
  // rendering all of it at once is both a performance problem and a
  // scroll-forever UX problem. Instead we show one month at a time,
  // centered on today, with explicit "Load Earlier"/"Load Later" buttons.
  // Deliberately NOT auto-loading on scroll: scroll-triggered loading is
  // hard for keyboard/screen-reader users to trigger predictably, while a
  // button is a normal, fully operable control for everyone.
  function monthKeyOf(dateStr: string): string {
    return dateStr.slice(0, 7);
  }
  function monthKeyLabel(key: string): string {
    const [y, m] = key.split("-").map(Number);
    return new Date(y, m - 1, 1).toLocaleDateString("en-US", { month: "long", year: "numeric" });
  }
  function groupByMonth(events: CalEvent[]): Map<string, CalEvent[]> {
    const map = new Map<string, CalEvent[]>();
    for (const e of events) {
      const key = monthKeyOf(e.date);
      if (!map.has(key)) map.set(key, []);
      map.get(key)!.push(e);
    }
    return map;
  }
  function findTodayMonthIndex(monthKeys: string[]): number {
    if (monthKeys.length === 0) return 0;
    const todayKey = monthKeyOf(ymd(new Date()));
    const idx = monthKeys.findIndex((k) => k >= todayKey);
    return idx === -1 ? monthKeys.length - 1 : idx;
  }

  function renderWindowed(
    container: HTMLElement,
    events: CalEvent[],
    buildMonthContent: (monthEvents: CalEvent[]) => HTMLElement,
  ): void {
    container.replaceChildren();
    if (events.length === 0) {
      container.appendChild(emptyMessage("No games scheduled this season yet."));
      return;
    }

    const byMonth = groupByMonth(events);
    const monthKeys = [...byMonth.keys()].sort();

    if (
      state.windowStart < 0 ||
      state.windowStart >= monthKeys.length ||
      state.windowEnd < 0 ||
      state.windowEnd >= monthKeys.length
    ) {
      state.windowStart = findTodayMonthIndex(monthKeys);
      state.windowEnd = state.windowStart;
    }

    const wrap = el("div", "space-y-8");

    if (state.windowStart > 0) {
      const btn = el(
        "button",
        "w-full rounded-md border border-ink-200 py-2 text-sm font-medium text-ink-600 hover:bg-ink-50",
        `↑ Load Earlier (${monthKeyLabel(monthKeys[state.windowStart - 1])})`,
      );
      btn.type = "button";
      btn.addEventListener("click", () => {
        state.windowStart -= 1;
        render();
        // Move focus to the newly revealed month heading so keyboard/screen
        // reader users land on the new content instead of losing their place.
        document.getElementById("calendar-window-top-heading")?.focus();
      });
      wrap.appendChild(btn);
    }

    for (let i = state.windowStart; i <= state.windowEnd; i++) {
      const key = monthKeys[i];
      const section = el("div");
      const heading = el("h2", "mb-3 text-sm font-semibold uppercase tracking-wide text-ink-500", monthKeyLabel(key));
      if (i === state.windowStart) {
        heading.id = "calendar-window-top-heading";
        heading.tabIndex = -1;
      }
      section.appendChild(heading);
      section.appendChild(buildMonthContent(byMonth.get(key)!));
      wrap.appendChild(section);
    }

    if (state.windowEnd < monthKeys.length - 1) {
      const btn = el(
        "button",
        "w-full rounded-md border border-ink-200 py-2 text-sm font-medium text-ink-600 hover:bg-ink-50",
        `↓ Load Later (${monthKeyLabel(monthKeys[state.windowEnd + 1])})`,
      );
      btn.type = "button";
      btn.addEventListener("click", () => {
        state.windowEnd += 1;
        render();
      });
      wrap.appendChild(btn);
    }

    container.appendChild(wrap);
  }

  // ── Views ────────────────────────────────────────────────────────────────
  function buildAgendaMonth(monthEvents: CalEvent[]): HTMLElement {
    const byDate = groupByDate(monthEvents);
    const dates = [...byDate.keys()].sort();
    const wrap = el("div", "space-y-6");
    for (const dateStr of dates) {
      const section = el("div");
      const heading = el(
        "h3",
        "mb-2 text-sm font-semibold uppercase tracking-wide text-ink-500",
        parseLocalDate(dateStr).toLocaleDateString("en-US", {
          weekday: "long",
          month: "long",
          day: "numeric",
        }),
      );
      section.appendChild(heading);
      const list = el("div", "space-y-2");
      for (const ev of byDate.get(dateStr)!) list.appendChild(buildEventRow(ev));
      section.appendChild(list);
      wrap.appendChild(section);
    }
    return wrap;
  }

  function renderAgenda(container: HTMLElement, events: CalEvent[]): void {
    renderWindowed(container, events, buildAgendaMonth);
  }

  function renderDay(container: HTMLElement, events: CalEvent[], anchor: Date): void {
    container.replaceChildren();
    const dateStr = ymd(anchor);
    const dayEvents = events.filter((e) => e.date === dateStr);
    if (dayEvents.length === 0) {
      container.appendChild(emptyMessage("No games scheduled this day."));
      return;
    }
    const list = el("div", "space-y-2");
    for (const ev of dayEvents) list.appendChild(buildEventRow(ev));
    container.appendChild(list);
  }

  // Richer week-view card — this calendar shows every sport at once (not a
  // filtered subset), so a visitor scanning a day column needs to tell
  // sports apart at a glance: sport name leads (bold), not the opponent,
  // since "which of my kid's games is this" is the first question. Home
  // games get a solid accent bar; away games a muted one — cheap, doesn't
  // need a legend, and matches the Home/Away badge convention used
  // everywhere else on the site.
  function buildWeekCard(ev: CalEvent): HTMLElement {
    const card = el(
      "div",
      "rounded-md border-l-4 bg-surface px-2 py-1.5 text-[11px] leading-tight shadow-sm " +
        (ev.isCancelled || ev.isPostponed
          ? "border-ink-200 opacity-60"
          : ev.homeOrAway === "Home"
            ? "border-primary-600"
            : "border-ink-300"),
    );

    const topRow = el("div", "flex items-start justify-between gap-1");
    const sportLink = el("a", "truncate text-xs font-semibold text-ink-900 hover:text-primary-600", ev.sportName);
    sportLink.href = ev.teamHref;
    topRow.appendChild(sportLink);
    topRow.appendChild(el("span", "shrink-0 text-[10px] font-medium uppercase text-ink-400", ev.levelAbbrev));
    card.appendChild(topRow);

    const oppRow = el("div", "mt-1 flex items-center gap-1.5");
    if (ev.opponentLogoUrl) {
      const img = el("img", "h-4 w-4 shrink-0 object-contain");
      img.src = ev.opponentLogoUrl;
      img.alt = "";
      img.loading = "lazy";
      oppRow.appendChild(img);
    }
    const vsOrAt = ev.homeOrAway === "Home" ? "vs" : ev.homeOrAway === "Away" ? "@" : "";
    oppRow.appendChild(el("p", "truncate text-ink-700", `${vsOrAt} ${ev.opponentName}`.trim()));
    card.appendChild(oppRow);

    const metaBits = [ev.time ?? "TBD"];
    if (ev.location) metaBits.push(ev.location);
    card.appendChild(el("p", "mt-1 truncate text-[10px] text-ink-400", metaBits.join(" · ")));

    if (ev.isCancelled || ev.isPostponed || ev.isConferenceGame || (ev.result && ev.homeScore !== null)) {
      const statusRow = el("div", "mt-1 flex flex-wrap items-center gap-1");
      if (ev.isCancelled) statusRow.appendChild(badge("Cancelled", "bg-ink-100 text-ink-600"));
      else if (ev.isPostponed) statusRow.appendChild(badge("Postponed", "bg-ink-100 text-ink-600"));
      else if (ev.result && ev.homeScore !== null && ev.awayScore !== null) {
        const cls = ev.result === "W" ? "text-green-700" : ev.result === "L" ? "text-red-700" : "text-ink-600";
        statusRow.appendChild(el("span", `text-[10px] font-semibold ${cls}`, `${ev.result} ${ev.homeScore}-${ev.awayScore}`));
      }
      if (ev.isConferenceGame) statusRow.appendChild(badge("Conf", "bg-primary-50 text-primary-700"));
      card.appendChild(statusRow);
    }

    return card;
  }

  function renderWeek(container: HTMLElement, events: CalEvent[], anchor: Date): void {
    container.replaceChildren();
    const start = startOfWeek(anchor);
    const byDate = groupByDate(events);
    const grid = el("div", "grid grid-cols-1 gap-3 sm:grid-cols-7");
    const todayStr = ymd(new Date());
    for (let i = 0; i < 7; i++) {
      const day = addDays(start, i);
      const dateStr = ymd(day);
      const col = el("div", "rounded-lg border border-ink-100 p-2" + (dateStr === todayStr ? " bg-primary-50/40" : ""));
      col.appendChild(
        el("p", "mb-2 text-xs font-semibold uppercase tracking-wide text-ink-400", day.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" })),
      );
      const dayEvents = byDate.get(dateStr) ?? [];
      if (dayEvents.length === 0) {
        col.appendChild(el("p", "text-xs text-ink-300", "—"));
      } else {
        const list = el("div", "space-y-2");
        for (const ev of dayEvents) list.appendChild(buildWeekCard(ev));
        col.appendChild(list);
      }
      grid.appendChild(col);
    }
    container.appendChild(grid);
  }

  // Month-cell pill — same "sport leads, home/away as an accent bar" idea as
  // the week card, just condensed to two lines since a busy day can have
  // 10+ events and the cell still has to fit a handful of these plus a
  // "+N more" line. Deliberately shows fewer events (2, was 3) but with
  // real content each, since 3 opponent-only lines told you nothing about
  // which sport it even was — the day cell is a preview, not the full list;
  // Day view (one tap away) has the rest.
  function buildMonthPill(ev: CalEvent): HTMLElement {
    const pill = el(
      "div",
      "rounded border-l-2 px-1 py-0.5 text-[10px] leading-tight " +
        (ev.isCancelled || ev.isPostponed
          ? "border-ink-200 bg-ink-50 text-ink-400 line-through"
          : ev.homeOrAway === "Home"
            ? "border-primary-600 bg-primary-50 text-primary-900"
            : "border-ink-300 bg-ink-100 text-ink-700"),
    );
    const topRow = el("div", "flex items-center gap-1");
    if (ev.opponentLogoUrl) {
      const img = el("img", "h-2.5 w-2.5 shrink-0 object-contain");
      img.src = ev.opponentLogoUrl;
      img.alt = "";
      img.loading = "lazy";
      topRow.appendChild(img);
    }
    topRow.appendChild(el("span", "truncate font-semibold", ev.sportName));
    topRow.appendChild(el("span", "ml-auto shrink-0 text-[9px] uppercase opacity-80", ev.levelAbbrev));
    pill.appendChild(topRow);
    const vsOrAt = ev.homeOrAway === "Home" ? "vs" : ev.homeOrAway === "Away" ? "@" : "";
    pill.appendChild(el("p", "truncate", `${vsOrAt} ${ev.opponentName}`.trim()));
    return pill;
  }

  function renderMonth(container: HTMLElement, events: CalEvent[], anchor: Date, onDayActivate: (date: Date) => void): void {
    container.replaceChildren();
    const year = anchor.getFullYear();
    const month = anchor.getMonth();
    const byDate = groupByDate(events);
    const firstWeekday = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const todayStr = ymd(new Date());
    const VISIBLE_CAP = 2;

    const wrap = el("div", "overflow-hidden rounded-lg border border-ink-100");
    const header = el("div", "grid grid-cols-7 border-b border-ink-100 bg-ink-50");
    for (const label of ["Su", "Mo", "Tu", "We", "Th", "Fr", "Sa"]) {
      header.appendChild(el("div", "px-1 py-1.5 text-center text-[11px] font-semibold uppercase tracking-wide text-ink-400", label));
    }
    wrap.appendChild(header);

    const grid = el("div", "grid grid-cols-7");
    const totalCells = Math.ceil((firstWeekday + daysInMonth) / 7) * 7;
    for (let i = 0; i < totalCells; i++) {
      const dayNum = i - firstWeekday + 1;
      const inMonth = dayNum >= 1 && dayNum <= daysInMonth;
      const cellDate = new Date(year, month, dayNum);
      const dateStr = ymd(cellDate);
      const cellEvents = inMonth ? (byDate.get(dateStr) ?? []) : [];

      const cell = el(
        "div",
        "min-h-[7.5rem] border-b border-r border-ink-100 p-1 [&:nth-child(7n)]:border-r-0" +
          (!inMonth ? " bg-ink-50/50" : dateStr === todayStr ? " bg-primary-50/40" : ""),
      );
      if (inMonth) {
        cell.appendChild(el("p", "px-0.5 text-[11px] text-ink-400", String(dayNum)));
        if (cellEvents.length > 0) {
          const btn = el("button", "mt-0.5 block w-full space-y-1 text-left");
          btn.type = "button";
          btn.setAttribute(
            "aria-label",
            `${cellEvents.length} game${cellEvents.length === 1 ? "" : "s"} on ${cellDate.toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric" })}, view day`,
          );
          for (const ev of cellEvents.slice(0, VISIBLE_CAP)) btn.appendChild(buildMonthPill(ev));
          if (cellEvents.length > VISIBLE_CAP) {
            btn.appendChild(el("p", "px-1 text-[10px] font-medium text-ink-400", `+${cellEvents.length - VISIBLE_CAP} more`));
          }
          btn.addEventListener("click", () => onDayActivate(cellDate));
          cell.appendChild(btn);
        }
      }
      grid.appendChild(cell);
    }
    wrap.appendChild(grid);
    container.appendChild(wrap);
  }

  // ── Controller ───────────────────────────────────────────────────────────
  const state: {
    view: "agenda" | "month" | "week" | "day";
    anchor: Date;
    sportId: string;
    level: string;
    windowStart: number;
    windowEnd: number;
  } = {
    view: "agenda",
    anchor: new Date(),
    sportId: "all",
    level: "all",
    windowStart: -1,
    windowEnd: -1,
  };

  const contentEl = document.getElementById("calendar-content")!;
  const periodLabelEl = document.getElementById("calendar-period-label")!;
  const prevBtn = document.getElementById("calendar-prev") as HTMLButtonElement;
  const nextBtn = document.getElementById("calendar-next") as HTMLButtonElement;
  const todayBtn = document.getElementById("calendar-today") as HTMLButtonElement;
  const sportFilter = document.getElementById("calendar-sport-filter") as HTMLSelectElement;
  const levelFilter = document.getElementById("calendar-level-filter") as HTMLSelectElement;
  const viewButtons = document.querySelectorAll<HTMLButtonElement>("[data-view-btn]");

  function filteredEvents(): CalEvent[] {
    return allEvents.filter((e) => {
      if (state.sportId !== "all" && e.sportId !== state.sportId) return false;
      if (state.level !== "all" && e.levelGroup !== state.level) return false;
      return true;
    });
  }

  function render(): void {
    const events = filteredEvents();
    const isAgenda = state.view === "agenda";
    prevBtn.hidden = isAgenda;
    nextBtn.hidden = isAgenda;
    todayBtn.hidden = isAgenda;

    if (state.view === "agenda") {
      periodLabelEl.textContent = "Full Season";
      renderAgenda(contentEl, events);
    } else if (state.view === "month") {
      prevBtn.setAttribute("aria-label", "Previous month");
      nextBtn.setAttribute("aria-label", "Next month");
      periodLabelEl.textContent = state.anchor.toLocaleDateString("en-US", { month: "long", year: "numeric" });
      renderMonth(contentEl, events, state.anchor, (date) => {
        state.view = "day";
        state.anchor = date;
        syncViewButtons();
        render();
      });
    } else if (state.view === "week") {
      prevBtn.setAttribute("aria-label", "Previous week");
      nextBtn.setAttribute("aria-label", "Next week");
      const start = startOfWeek(state.anchor);
      const end = addDays(start, 6);
      const sameMonth = start.getMonth() === end.getMonth();
      periodLabelEl.textContent = sameMonth
        ? `${start.toLocaleDateString("en-US", { month: "long" })} ${start.getDate()}–${end.getDate()}, ${end.getFullYear()}`
        : `${start.toLocaleDateString("en-US", { month: "short", day: "numeric" })} – ${end.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}`;
      renderWeek(contentEl, events, state.anchor);
    } else {
      prevBtn.setAttribute("aria-label", "Previous day");
      nextBtn.setAttribute("aria-label", "Next day");
      periodLabelEl.textContent = state.anchor.toLocaleDateString("en-US", {
        weekday: "long",
        month: "long",
        day: "numeric",
        year: "numeric",
      });
      renderDay(contentEl, events, state.anchor);
    }
  }

  function syncViewButtons(): void {
    viewButtons.forEach((btn) => {
      btn.setAttribute("aria-pressed", String(btn.dataset.viewBtn === state.view));
    });
  }

  viewButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      state.view = btn.dataset.viewBtn as typeof state.view;
      state.windowStart = -1;
      state.windowEnd = -1;
      syncViewButtons();
      render();
    });
  });

  prevBtn.addEventListener("click", () => {
    if (state.view === "month") state.anchor = addMonths(state.anchor, -1);
    else if (state.view === "week") state.anchor = addDays(state.anchor, -7);
    else state.anchor = addDays(state.anchor, -1);
    render();
  });
  nextBtn.addEventListener("click", () => {
    if (state.view === "month") state.anchor = addMonths(state.anchor, 1);
    else if (state.view === "week") state.anchor = addDays(state.anchor, 7);
    else state.anchor = addDays(state.anchor, 1);
    render();
  });
  todayBtn.addEventListener("click", () => {
    state.anchor = new Date();
    render();
  });
  sportFilter.addEventListener("change", () => {
    state.sportId = sportFilter.value;
    state.windowStart = -1;
    state.windowEnd = -1;
    render();
  });
  levelFilter.addEventListener("change", () => {
    state.level = levelFilter.value;
    state.windowStart = -1;
    state.windowEnd = -1;
    render();
  });

  render();
</script>
