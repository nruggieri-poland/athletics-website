---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArticles, mediaUrl } from "../../lib/payload";
import { lexicalToHtml } from "../../lib/lexical";

export async function getStaticPaths() {
  const { docs: articles } = await getArticles(500, 1);
  // External Link and PDF articles never link here — their cards go
  // straight to the external URL or the PDF file — so there is nothing to
  // render for them (no body content is even collected for those types).
  return articles
    .filter((article) => article.linkType === "article")
    .map((article) => ({
      params: { slug: article.slug },
      props: { article },
    }));
}

const { article } = Astro.props;
const bodyHtml = lexicalToHtml(article.body);
const formattedDate = new Date(article.publishedDate).toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<BaseLayout title={article.title} description={article.excerpt}>
  <article class="mx-auto max-w-content px-6 py-16">
    <div class="mx-auto max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-wide text-primary-600">{formattedDate}</p>
      <h1 class="mt-2 text-h1 font-bold text-ink-900">{article.title}</h1>
    </div>

    <div class="mx-auto mt-8 max-w-3xl overflow-hidden rounded-xl bg-ink-100">
      <img
        src={mediaUrl(article.heroImage, "hero")}
        alt={article.heroImage.alt}
        class="w-full object-cover"
      />
    </div>

    <div
      class="prose mx-auto mt-10 max-w-2xl prose-headings:font-semibold"
      set:html={bodyHtml}
    />
  </article>
</BaseLayout>
