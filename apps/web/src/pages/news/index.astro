---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/articles/ArticleCard.astro";
import { getArticles } from "../../lib/payload";

const { docs: articles } = await getArticles(50, 1);
---

<BaseLayout title="News" description="Latest news from Poland Seminary Bulldogs Athletics">
  <section class="mx-auto max-w-content px-6 py-16">
    <h1 class="mb-10 text-h1 font-bold text-ink-900">News</h1>
    {articles.length > 0 ? (
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((article) => <ArticleCard article={article} />)}
      </div>
    ) : (
      <p class="text-ink-400">No articles published yet.</p>
    )}
  </section>
</BaseLayout>
