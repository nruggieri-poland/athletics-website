---
interface Contact {
  role: string;
  name: string;
  meta: string;
}

interface Props {
  contacts: Contact[];
}

const { contacts } = Astro.props;
---

<div class="grid gap-3 sm:grid-cols-3">
  {contacts.map((contact) => (
    <div class="rounded-lg border border-ink-100 p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-ink-400">{contact.role}</p>
      <p class="mt-1 text-sm font-semibold text-ink-900">{contact.name}</p>
      <p class="mt-0.5 text-sm text-ink-500">{contact.meta}</p>
    </div>
  ))}
</div>
