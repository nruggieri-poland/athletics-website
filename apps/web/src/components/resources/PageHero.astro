---
interface Props {
  section: string;
  title: string;
  lede: string;
}

const { section, title, lede } = Astro.props;
---

<div class="border-b border-ink-100 py-12">
  <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-primary-600">
    <a href="/resources" class="hover:text-primary-700">Resources</a> / {section}
  </p>
  <h1 class="max-w-[20ch] text-h1 font-bold text-ink-900">{title}</h1>
  <p class="mt-3 max-w-[62ch] text-lg text-ink-600">{lede}</p>
</div>
