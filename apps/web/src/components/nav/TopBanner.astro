---
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  address?: string;
  socialLinks?: { platform: string; url: string }[];
}

const { address, socialLinks = [] } = Astro.props;

// Minimal 20x20 monochrome glyphs — no external icon library, matches the
// hand-built SVG pattern used everywhere else in this codebase.
const ICON_PATHS: Record<string, string> = {
  facebook:
    "M13 10h2.5l.4-3H13V5.3c0-.87.24-1.46 1.48-1.46H16V1.14C15.73 1.1 14.8 1 13.72 1 11.46 1 9.9 2.37 9.9 5.02V7H7.4v3h2.5v8h3.1v-8Z",
  twitter:
    "M17.5 4.8a5.9 5.9 0 0 1-1.7.47 2.98 2.98 0 0 0 1.3-1.65c-.57.34-1.2.58-1.87.72a2.94 2.94 0 0 0-5 2.68A8.34 8.34 0 0 1 4.1 3.83a2.94 2.94 0 0 0 .91 3.92 2.9 2.9 0 0 1-1.33-.37v.04a2.94 2.94 0 0 0 2.36 2.88 2.95 2.95 0 0 1-1.33.05 2.94 2.94 0 0 0 2.75 2.04A5.9 5.9 0 0 1 2 13.6a8.3 8.3 0 0 0 4.5 1.32c5.4 0 8.36-4.48 8.36-8.36l-.01-.38A5.9 5.9 0 0 0 17.5 4.8Z",
  instagram:
    "M10 6.35a3.65 3.65 0 1 0 0 7.3 3.65 3.65 0 0 0 0-7.3Zm0 6.02a2.37 2.37 0 1 1 0-4.74 2.37 2.37 0 0 1 0 4.74Zm4.65-6.17a.85.85 0 1 1-1.7 0 .85.85 0 0 1 1.7 0ZM17.96 6c-.05-1.16-.32-2.19-1.16-3.02-.83-.84-1.86-1.1-3.02-1.16-1.19-.07-4.76-.07-5.95 0-1.16.05-2.18.32-3.02 1.15-.84.84-1.1 1.86-1.16 3.02-.07 1.19-.07 4.76 0 5.95.06 1.16.32 2.19 1.16 3.02.84.84 1.86 1.1 3.02 1.16 1.19.07 4.76.07 5.95 0 1.16-.06 2.19-.32 3.02-1.16.84-.83 1.1-1.86 1.16-3.02.07-1.19.07-4.75 0-5.94Zm-1.54 7.22a2.47 2.47 0 0 1-1.39 1.4c-.97.38-3.26.3-4.33.3s-3.37.08-4.33-.3a2.47 2.47 0 0 1-1.4-1.4c-.38-.96-.3-3.25-.3-4.32s-.08-3.37.3-4.33a2.47 2.47 0 0 1 1.4-1.4c.96-.37 3.26-.3 4.33-.3s3.36-.07 4.33.3c.65.25 1.15.75 1.4 1.4.37.97.29 3.26.29 4.33s.08 3.36-.3 4.32Z",
  youtube:
    "M18.5 6.2s-.18-1.3-.75-1.87c-.72-.76-1.53-.76-1.9-.8C13.2 3.3 10 3.3 10 3.3h-.01s-3.2 0-5.85.23c-.37.04-1.18.04-1.9.8-.57.57-.75 1.87-.75 1.87S1.3 7.72 1.3 9.25v1.43c0 1.53.2 3.06.2 3.06s.18 1.3.75 1.87c.72.76 1.66.73 2.08.82C5.8 16.6 10 16.68 10 16.68s3.2-.01 5.85-.24c.37-.04 1.18-.04 1.9-.8.57-.57.75-1.87.75-1.87s.2-1.53.2-3.06V9.25c0-1.53-.2-3.05-.2-3.05ZM8.14 12.2V6.9l4.55 2.66-4.55 2.65Z",
};

const iconLabel: Record<string, string> = {
  facebook: "Facebook",
  twitter: "Twitter",
  instagram: "Instagram",
  youtube: "YouTube",
};
---

<div class="border-b border-white/10 bg-primary-900 text-white">
  <div class="mx-auto flex max-w-content items-center justify-between gap-4 px-6 py-2">
    <p class="truncate text-xs text-white/80">{address}</p>
    <div class="flex shrink-0 items-center gap-3">
      {socialLinks.filter((link) => link.url).map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={iconLabel[link.platform] ?? link.platform}
          class="text-white/80 hover:text-white"
        >
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path d={ICON_PATHS[link.platform] ?? ""} />
          </svg>
        </a>
      ))}
      <ThemeToggle class="text-white/80 hover:bg-white/10 hover:text-white" />
    </div>
  </div>
</div>
