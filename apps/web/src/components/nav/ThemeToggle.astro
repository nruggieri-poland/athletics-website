---
interface Props {
  class?: string;
}
const { class: className = "text-ink-600 hover:bg-ink-50" } = Astro.props;
---

<button
  type="button"
  data-theme-toggle
  class:list={["flex h-9 w-9 shrink-0 items-center justify-center rounded-md", className]}
  aria-label="Switch to dark mode"
>
  <svg data-theme-icon="sun" class="hidden h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
    <circle cx="10" cy="10" r="3.5" />
    <path stroke-linecap="round" d="M10 2.5v2M10 15.5v2M17.5 10h-2M4.5 10h-2M15.4 4.6l-1.4 1.4M5.99 14.02l-1.4 1.4M15.4 15.4l-1.4-1.4M5.99 5.99 4.6 4.6" />
  </svg>
  <svg data-theme-icon="moon" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
    <path d="M17.293 13.293A8 8 0 0 1 6.707 2.707a8.001 8.001 0 1 0 10.586 10.586Z" />
  </svg>
</button>

<script>
  // A page can have more than one instance of this component (e.g. the top
  // banner and the footer both show a toggle) — Astro only inlines this
  // script once per page regardless of how many instances render, so it's
  // safe to just wire up every matching button found at once and keep them
  // all in sync.
  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");
  const darkMediaQuery = window.matchMedia("(prefers-color-scheme: dark)");

  function currentTheme(): "light" | "dark" {
    const stored = document.documentElement.getAttribute("data-theme");
    if (stored === "dark" || stored === "light") return stored;
    return darkMediaQuery.matches ? "dark" : "light";
  }

  function syncButtons(): void {
    const theme = currentTheme();
    buttons.forEach((button) => {
      button.querySelector('[data-theme-icon="sun"]')?.classList.toggle("hidden", theme !== "dark");
      button.querySelector('[data-theme-icon="moon"]')?.classList.toggle("hidden", theme === "dark");
      button.setAttribute("aria-label", theme === "dark" ? "Switch to light mode" : "Switch to dark mode");
    });
  }

  syncButtons();
  darkMediaQuery.addEventListener("change", () => {
    if (!document.documentElement.getAttribute("data-theme")) syncButtons();
  });

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const next = currentTheme() === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      try {
        localStorage.setItem("theme", next);
      } catch {
        // Private browsing / storage disabled — theme still applies for this
        // page load via the attribute, it just won't persist to the next visit.
      }
      syncButtons();
    });
  });
</script>
