---
import type { Game } from "../../lib/payload";
import GameTile from "./GameTile.astro";
import Carousel from "../shared/Carousel.astro";

interface Props {
  games: Game[];
}

const { games } = Astro.props;
---

{games.length > 0 && (
  <Carousel>
    {games.map((game) => <GameTile game={game} />)}
  </Carousel>
)}
