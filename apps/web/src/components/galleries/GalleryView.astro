---
import type { Gallery } from "../../lib/payload";
import GalleryItemCard from "./GalleryItemCard.astro";

interface Props {
  gallery: Gallery;
  emptyLabel?: string;
}

const { gallery, emptyLabel = "Nothing here yet — check back soon." } = Astro.props;

const sections = gallery.sections.filter((section) => section.items.length > 0);
---

{gallery.description && <p class="mb-8 text-ink-500">{gallery.description}</p>}

{sections.length === 0 ? (
  <p class="text-ink-400">{emptyLabel}</p>
) : (
  <div class="space-y-10">
    {sections.map((section) => (
      <div>
        {section.heading && (
          <h3 class="mb-4 text-sm font-semibold uppercase tracking-wide text-ink-500">{section.heading}</h3>
        )}
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {section.items.map((item) => (
            <GalleryItemCard item={item} />
          ))}
        </div>
      </div>
    ))}
  </div>
)}
