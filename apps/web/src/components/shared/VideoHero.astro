---
// Shared hero used on the home page and every sport hub page. Text
// treatment is deliberately minimal and heavy-handed rather than
// soft/marketing: bottom-anchored, oversized black-weight uppercase type,
// a thin accent rule, and a squared (not pill) outlined CTA — closer to a
// team-branding title card than a SaaS landing page.
interface Props {
  videoId?: string;
  kicker?: string;
  heading: string;
  tagline?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const { videoId, kicker, heading, tagline, ctaHref, ctaLabel } = Astro.props;
---

<section class="relative isolate flex h-[64vh] min-h-[380px] items-end overflow-hidden bg-[#101114]">
  {videoId && (
    <div class="absolute inset-0 -z-20" aria-hidden="true" data-hero-video-container>
      <template data-hero-video-template>
        <iframe
          class="pointer-events-none absolute left-1/2 top-1/2 h-[56.25vw] min-h-full w-[177.78vh] min-w-full -translate-x-1/2 -translate-y-1/2"
          src={`https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&showinfo=0&modestbranding=1&playsinline=1&rel=0&iv_load_policy=3&disablekb=1`}
          title=""
          tabindex="-1"
          style="border:0"
          allow="autoplay; encrypted-media"
        ></iframe>
      </template>
    </div>
  )}
  <div class="absolute inset-0 -z-10 bg-gradient-to-t from-black/90 via-black/40 to-black/10"></div>

  <div class="relative mx-auto w-full max-w-content px-6 pb-16 pt-24 text-white">
    <div class="mb-4 h-1 w-14 bg-primary-500"></div>
    {kicker && (
      <p class="text-xs font-semibold uppercase tracking-[0.35em] text-white/80">{kicker}</p>
    )}
    <h1 class="mt-3 text-hero font-black uppercase leading-[0.88] tracking-tight text-white">
      {heading}
    </h1>
    {tagline && (
      <p class="mt-5 max-w-md text-sm uppercase tracking-[0.15em] text-white/80">{tagline}</p>
    )}
    {ctaHref && ctaLabel && (
      <a
        href={ctaHref}
        class="mt-8 inline-flex items-center gap-3 border border-white/60 px-6 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-white transition hover:border-white hover:bg-white hover:text-black"
      >
        {ctaLabel}
        <span aria-hidden="true">&rarr;</span>
      </a>
    )}
  </div>

  {videoId && (
    <button
      type="button"
      data-hero-video-toggle
      aria-pressed="false"
      class="absolute bottom-4 right-4 z-10 flex items-center gap-2 rounded-full border border-white/40 bg-black/40 px-3 py-2 text-white backdrop-blur transition hover:border-white/70"
    >
      <svg data-icon-pause class="h-3.5 w-3.5" viewBox="0 0 12 12" fill="currentColor">
        <rect x="2" y="1.5" width="2.5" height="9" rx="0.5" />
        <rect x="7.5" y="1.5" width="2.5" height="9" rx="0.5" />
      </svg>
      <svg data-icon-play class="hidden h-3.5 w-3.5" viewBox="0 0 12 12" fill="currentColor">
        <path d="M2.5 1.5v9l7-4.5-7-4.5z" />
      </svg>
      <span data-label class="text-[11px] font-medium uppercase tracking-wide">Pause video</span>
    </button>
  )}
</section>

<script>
  // Purely decorative background video: skip it entirely for
  // prefers-reduced-motion, and always give every visitor a way to stop the
  // loop regardless of OS setting (WCAG 2.2.2 Pause, Stop, Hide).
  document.querySelectorAll<HTMLElement>("[data-hero-video-container]").forEach((container) => {
    const template = container.querySelector<HTMLTemplateElement>("[data-hero-video-template]");
    const toggle = container.parentElement?.querySelector<HTMLButtonElement>("[data-hero-video-toggle]");
    const pauseIcon = toggle?.querySelector<SVGElement>("[data-icon-pause]");
    const playIcon = toggle?.querySelector<SVGElement>("[data-icon-play]");
    const label = toggle?.querySelector<HTMLElement>("[data-label]");
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function setPlaying(playing: boolean) {
      if (playing) {
        if (template && !container.querySelector("iframe")) {
          container.appendChild(template.content.cloneNode(true));
        }
      } else {
        container.querySelector("iframe")?.remove();
      }
      toggle?.setAttribute("aria-pressed", String(!playing));
      pauseIcon?.classList.toggle("hidden", !playing);
      playIcon?.classList.toggle("hidden", playing);
      if (label) label.textContent = playing ? "Pause video" : "Play video";
    }

    setPlaying(!prefersReducedMotion);

    toggle?.addEventListener("click", () => {
      setPlaying(!container.querySelector("iframe"));
    });
  });
</script>
